  {
    "id": "8d367b60-de96-4f9f-8999-c25593686a28",
    "data": {
      "lang": "typescript",
      "content": [
        {
          "text": "import { NextResponse } from 'next/server';",
          "type": "line"
        },
        {
          "text": "import type { NextRequest } from 'next/server';",
          "type": "line"
        },
        {
          "text": "import { verifyAuthToken } from '@/lib/auth';",
          "type": "line"
        },
        {
          "text": "",
          "type": "line"
        },
        {
          "text": "export async function middleware(request: NextRequest) {",
          "type": "line"
        },
        {
          "text": "  const token = request.cookies.get('auth_token')?.value;",
          "type": "line"
        },
        {
          "text": "",
          "type": "line"
        },
        {
          "text": "  if (!token) {",
          "type": "line"
        },
        {
          "text": "    return NextResponse.redirect(new URL('/login', request.url));",
          "type": "line"
        },
        {
          "text": "  }",
          "type": "line"
        },
        {
          "text": "",
          "type": "line"
        },
        {
          "text": "  try {",
          "type": "line"
        },
        {
          "text": "    const user = await verifyAuthToken(token);",
          "type": "line"
        },
        {
          "text": "    if (!user || user.role !== 'Admin') {",
          "type": "line"
        },
        {
          "text": "      return NextResponse.redirect(new URL('/unauthorized', request.url));",
          "type": "line"
        },
        {
          "text": "    }",
          "type": "line"
        },
        {
          "text": "  } catch (error) {",
          "type": "line"
        },
        {
          "text": "    console.error('Auth verification failed:', error);",
          "type": "line"
        },
        {
          "text": "    return NextResponse.redirect(new URL('/login', request.url));",
          "type": "line"
        },
        {
          "text": "  }",
          "type": "line"
        },
        {
          "text": "",
          "type": "line"
        },
        {
          "text": "  return NextResponse.next();",
          "type": "line"
        },
        {
          "text": "}",
          "type": "line"
        },
        {
          "text": "",
          "type": "line"
        },
        {
          "text": "export const config = {",
          "type": "line"
        },
        {
          "text": "  matcher: ['/dashboard/:path*', '/admin/:path*'],",
          "type": "line"
        },
        {
          "text": "};",
          "type": "line"
        }
      ],
      "filename": "middleware.ts"
    },
    "type": "code-terminal",
    "width": "1/2",
    "sort_order": 4
  },
